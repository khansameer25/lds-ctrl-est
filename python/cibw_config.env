# Minimal cibuildwheel configuration

# Build these Python versions
CIBW_BUILD = "cp39-* cp310-* cp311-* cp312-*"

# Skip problematic builds
CIBW_SKIP = "*-win32 *-manylinux_i686 *-musllinux*"

# Use modern manylinux to avoid CentOS 7 issues
CIBW_MANYLINUX_X86_64_IMAGE = "manylinux_2_28"

# Simple system package approach - no vcpkg, add make, install cmake files
CIBW_BEFORE_ALL_LINUX = "dnf install -y cmake ninja-build gcc-c++ make openblas-devel hdf5-devel hdf5-static"
CIBW_BEFORE_ALL_MACOS = "brew install cmake ninja openblas hdf5"
CIBW_BEFORE_ALL_WINDOWS = "choco install cmake ninja"

# Build without vcpkg - patch CMakeLists.txt to skip HDF5 for Python builds
CIBW_BEFORE_BUILD = "pip install pybind11 numpy && sed -i 's|include(HDF5)|# include(HDF5) # Skipped for Python builds|' CMakeLists.txt && sed -i 's|include(Armadillo)|# include(Armadillo) # Skipped for Python builds|' CMakeLists.txt && cmake -B build -S . -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON -DLDSCTRLEST_BUILD_FITTING=OFF -DCMAKE_TOOLCHAIN_FILE= && cmake --build build --target python_modules"

# Test
CIBW_TEST_COMMAND = "python -c 'import ldsctrlest; print(\"Success!\")'"
