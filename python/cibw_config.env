# Minimal cibuildwheel configuration - use vcpkg as intended

# Build these Python versions
CIBW_BUILD = "cp39-* cp310-* cp311-* cp312-*"

# Skip problematic builds
CIBW_SKIP = "*-win32 *-manylinux_i686 *-musllinux*"

# Use modern manylinux to avoid CentOS 7 issues
CIBW_MANYLINUX_X86_64_IMAGE = "manylinux_2_28"

# Install basic build tools
CIBW_BEFORE_ALL_LINUX = "dnf install -y cmake ninja-build gcc-c++ gcc-gfortran make zip unzip tar"
CIBW_BEFORE_ALL_MACOS = "brew install cmake ninja"
CIBW_BEFORE_ALL_WINDOWS = "choco install cmake ninja"

# Simple build - let vcpkg handle dependencies
CIBW_BEFORE_BUILD = "pip install pybind11 numpy && cmake -B build -S . -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON -DLDSCTRLEST_BUILD_FITTING=OFF && cmake --build build --target python_modules"

# Minimal test - just check if it imports
CIBW_TEST_COMMAND = "python -c 'import ldsctrlest; print(\"SUCCESS!\")'"
