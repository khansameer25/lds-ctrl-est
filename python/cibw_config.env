# Minimal cibuildwheel configuration

# Build these Python versions
CIBW_BUILD = "cp39-* cp310-* cp311-* cp312-*"

# Skip problematic builds
CIBW_SKIP = "*-win32 *-manylinux_i686 *-musllinux*"

# Use modern manylinux to avoid CentOS 7 issues
CIBW_MANYLINUX_X86_64_IMAGE = "manylinux_2_28"

# Simple system package approach - no vcpkg, add make, install cmake files with static libs
CIBW_BEFORE_ALL_LINUX = "dnf install -y cmake ninja-build gcc-c++ gcc-gfortran make openblas-devel openblas-static lapack-devel lapack-static hdf5-devel hdf5-static libgfortran-static libquadmath-static && ls -la /usr/lib64/ | grep -E '(openblas|lapack|fortran|quadmath)'"
CIBW_BEFORE_ALL_MACOS = "brew install cmake ninja openblas hdf5"
CIBW_BEFORE_ALL_WINDOWS = "choco install cmake ninja"

# Build without vcpkg - patch CMakeLists.txt to skip HDF5 for Python builds and add static BLAS/LAPACK with explicit library paths
CIBW_BEFORE_BUILD = "pip install pybind11 numpy && sed -i 's|include(HDF5)|# include(HDF5) # Skipped for Python builds|' CMakeLists.txt && sed -i 's|include(Armadillo)|# include(Armadillo) # Skipped for Python builds|' CMakeLists.txt && sed -i 's|list(APPEND PROJECT_REQUIRED_LIBRARIES_ABSOLUTE_NAME carma::carma Python3::Python)|list(APPEND PROJECT_REQUIRED_LIBRARIES_ABSOLUTE_NAME carma::carma) # Python3::Python removed for wheel builds|' cmake/Modules/pybind11.cmake && sed -i '/^target_link_libraries(ldsCtrlEst PUBLIC \${PROJECT_REQUIRED_LIBRARIES_ABSOLUTE_NAME})/c\\target_link_libraries(ldsCtrlEst PUBLIC \${PROJECT_REQUIRED_LIBRARIES_ABSOLUTE_NAME} -Wl,--start-group /usr/lib64/libopenblas.a /usr/lib64/liblapack.a /usr/lib64/libgfortran.a /usr/lib64/libquadmath.a -Wl,--end-group -static-libgcc -static-libstdc++)' CMakeLists.txt && cmake -B build -S . -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON -DLDSCTRLEST_BUILD_FITTING=OFF -DCMAKE_TOOLCHAIN_FILE= && cmake --build build --target python_modules"

# Test with debugging - check for LAPACK symbols
CIBW_TEST_COMMAND = "find build -name '*.so' -exec nm -D {} \\; | grep -i 'dorgqr\\|lapack' | head -20 || echo 'No LAPACK symbols found' && python -c 'import ldsctrlest; print(\"Success!\")'"
