# Minimal cibuildwheel configuration

# Build these Python versions
CIBW_BUILD = "cp39-* cp310-* cp311-* cp312-*"

# Skip problematic builds
CIBW_SKIP = "*-win32 *-manylinux_i686 *-musllinux*"

# Use modern manylinux to avoid CentOS 7 issues
CIBW_MANYLINUX_X86_64_IMAGE = "manylinux_2_28"

# Simple system package approach - no vcpkg, add make, install cmake files with static libs
CIBW_BEFORE_ALL_LINUX = "dnf install -y cmake ninja-build gcc-c++ gcc-gfortran make openblas-devel openblas-static lapack-devel lapack-static hdf5-devel hdf5-static libgfortran-static libquadmath-static && ls -la /usr/lib64/ | grep -E '(openblas|lapack|fortran|quadmath)'"
CIBW_BEFORE_ALL_MACOS = "brew install cmake ninja openblas hdf5"
CIBW_BEFORE_ALL_WINDOWS = "choco install cmake ninja"

# Build without vcpkg - minimal working approach
CIBW_BEFORE_BUILD = "pip install pybind11 numpy && sed -i 's|include(HDF5)|# include(HDF5)|' CMakeLists.txt && sed -i 's|include(Armadillo)|# include(Armadillo)|' CMakeLists.txt && sed -i 's|Python3::Python||' cmake/Modules/pybind11.cmake && cmake -B build -S . -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON -DLDSCTRLEST_BUILD_FITTING=OFF && cmake --build build --target python_modules"

# Minimal test - just check if it imports
CIBW_TEST_COMMAND = "python -c 'import ldsctrlest; print(\"SUCCESS!\")'"
