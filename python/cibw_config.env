# Configuration for cibuildwheel

# Build these Python versions
CIBW_BUILD = "cp39-* cp310-* cp311-* cp312-*"

# Skip these builds
CIBW_SKIP = "*-win32 *-manylinux_i686 *-musllinux*"

# Build frontend
CIBW_BUILD_FRONTEND = "pip"

# Environment variables
CIBW_ENVIRONMENT_COMMON = "CMAKE_BUILD_PARALLEL_LEVEL=2 LDSCTRLEST_BUILD_PYTHON=ON"

# Linux configuration
CIBW_BEFORE_ALL_LINUX = """
    yum install -y ninja-build cmake3 gcc-c++ &&
    curl -L -O https://github.com/microsoft/vcpkg/archive/2024.11.16.tar.gz &&
    tar -xf 2024.11.16.tar.gz &&
    mv vcpkg-2024.11.16 vcpkg &&
    cd vcpkg && ./bootstrap-vcpkg.sh &&
    ./vcpkg install armadillo hdf5 --triplet=x64-linux
"""

CIBW_BEFORE_BUILD_LINUX = """
    pip install cmake ninja pybind11[global] numpy &&
    export CMAKE_TOOLCHAIN_FILE={project}/vcpkg/scripts/buildsystems/vcpkg.cmake &&
    cmake -B {project}/build -S {project} -GNinja -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON -DCMAKE_TOOLCHAIN_FILE={project}/vcpkg/scripts/buildsystems/vcpkg.cmake &&
    cmake --build {project}/build --target python_modules
"""

# macOS configuration  
CIBW_BEFORE_ALL_MACOS = "brew install cmake ninja armadillo hdf5"

CIBW_BEFORE_BUILD_MACOS = """
    pip install cmake ninja pybind11[global] numpy &&
    cmake -B {project}/build -S {project} -GNinja -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON &&
    cmake --build {project}/build --target python_modules
"""

# Windows configuration
CIBW_BEFORE_ALL_WINDOWS = """
    git clone https://github.com/Microsoft/vcpkg.git &&
    cd vcpkg && .\\bootstrap-vcpkg.bat &&
    .\\vcpkg install armadillo hdf5 --triplet=x64-windows
"""

CIBW_BEFORE_BUILD_WINDOWS = """
    pip install cmake ninja pybind11[global] numpy &&
    cmake -B {project}/build -S {project} -G"Visual Studio 17 2022" -DCMAKE_BUILD_TYPE=Release -DLDSCTRLEST_BUILD_PYTHON=ON -DCMAKE_TOOLCHAIN_FILE={project}/vcpkg/scripts/buildsystems/vcpkg.cmake &&
    cmake --build {project}/build --config Release --target python_modules
"""

# Repair wheels
CIBW_REPAIR_WHEEL_COMMAND_LINUX = "auditwheel repair -w {dest_dir} {wheel}"
CIBW_REPAIR_WHEEL_COMMAND_MACOS = "delocate-wheel --require-archs {delocate_archs} -w {dest_dir} -v {wheel}"

# Test configuration
CIBW_TEST_REQUIRES = "pytest numpy"
CIBW_TEST_COMMAND = "python -c \"import ldsctrlest; print('ldsctrlest imported successfully')\""
